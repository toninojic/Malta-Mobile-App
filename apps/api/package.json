{
  "name": "@malta-marketplace/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:seed:clean": "node scripts/reset-clean-test-db.mjs",
    "db:reset-clean": "prisma migrate reset --force --skip-seed --skip-generate && node scripts/reset-clean-test-db.mjs",
    "smoke:milestone1": "node scripts/milestone1-smoke.mjs",
    "smoke:milestone2": "node scripts/milestone2-smoke.mjs",
    "smoke:milestone3": "node scripts/milestone3-smoke.mjs",
    "smoke:milestone4": "node scripts/milestone4-smoke.mjs",
    "smoke:milestone5": "node scripts/milestone5-smoke.mjs",
    "smoke:milestone6": "node scripts/milestone6-smoke.mjs",
    "smoke:milestone7": "node scripts/milestone7-smoke.mjs",
    "smoke:milestone8": "node scripts/milestone8-smoke.mjs",
    "smoke:milestone8b": "node scripts/milestone8b-smoke.mjs",
    "smoke:qa-mobile-ux": "node scripts/qa-mobile-ux-smoke.mjs",
    "smoke:qa-fixes": "node scripts/qa-fixes-smoke.mjs",
    "smoke:flow-refactor": "node scripts/flow-refactor-smoke.mjs",
    "smoke:ux-consolidation": "node scripts/ux-consolidation-smoke.mjs",
    "smoke:final-flow-fixes": "node scripts/final-flow-fixes-smoke.mjs",
    "smoke:revenuecat-webhook": "node scripts/revenuecat-webhook-smoke.mjs",
    "smoke:milestone10": "node scripts/milestone10-smoke.mjs",
    "smoke:ai-job-assistant": "node scripts/ai-job-assistant-smoke.mjs",
    "smoke:admin-token-grants": "node scripts/admin-token-grants-smoke.mjs",
    "smoke:report-system": "node scripts/report-system-smoke.mjs"
