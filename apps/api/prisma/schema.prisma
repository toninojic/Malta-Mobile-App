generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  EMPLOYER
  CONTRACTOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum UserAuthProvider {
  EMAIL
  GOOGLE
  BOTH
}

enum JobStatus {
  ACTIVE
  IN_PROGRESS
  EXPIRED
  COMPLETED
  CLOSED
}

enum OfferStatus {
  PENDING
  SELECTED
  REJECTED
  WITHDRAWN
  COMPLETED
}

enum OfferRejectionReason {
  AUTO_REJECTED_BY_SELECTION
  MANUALLY_REJECTED_BY_EMPLOYER
  SELECTION_CANCELLED_BY_EMPLOYER
  JOB_CLOSED
}

enum TokenTransactionType {
  PURCHASE
  SPEND
  REFUND
  ADMIN_GRANT
  ADMIN_REVOKE
  WELCOME_BONUS
  REFERRAL_BONUS
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PaymentStatus {
  PENDING
  PAID
  COMPLETED
  FAILED
  REFUNDED
  IGNORED
}

enum PaymentProvider {
  MOCK
  REVENUECAT
  LEGACY_STRIPE
}

enum StorePlatform {
  IOS
  ANDROID
  REVENUECAT
}

enum ContactUnlockStatus {
  PENDING
  UNLOCKED
}

enum JobCompletionStatus {
  PENDING_EMPLOYER_CONFIRMATION
  CONFIRMED
  DISPUTED
  CANCELLED
}

enum ReviewStatus {
  ACTIVE
  REMOVED
}

enum ContractorVerificationStatus {
  UNVERIFIED
  PENDING_REVIEW
  VERIFIED
  REJECTED
}

enum NotificationType {
  ACCOUNT_SUSPENDED
  ACCOUNT_ACTIVATED
  NEW_JOB_NEARBY
  NEW_OFFER
  OFFER_SELECTED
  NEW_MESSAGE
  CONTACT_UNLOCKED
  REFUND_APPROVED
  REFUND_DENIED
  REFUND_REJECTED
  JOB_COMPLETED
  REVIEW_RECEIVED
  REVIEW_REPLIED
  REVIEW_REMOVED
  CONTRACTOR_VERIFICATION_APPROVED
  CONTRACTOR_VERIFICATION_REJECTED
  SYSTEM_ALERT
  NEW_REPORT
  REPORT_STATUS_UPDATED
  NEW_VERIFICATION_REQUEST
  NEW_REFUND_REQUEST
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VOICE
}

enum AiConversationStatus {
  ACTIVE
  COMPLETED
  DISCARDED
}

enum AiMessageRole {
  USER
  ASSISTANT
}

enum AiJobDraftStatus {
  DRAFT
  PUBLISHED
  DISCARDED
}

enum ReportTargetType {
  USER
  JOB
  OFFER
  CONVERSATION
  MESSAGE
  REVIEW
}

enum ReportReason {
  SPAM
  SCAM_OR_FRAUD
  HARASSMENT
  INAPPROPRIATE_CONTENT
  FAKE_PROFILE
  CONTACT_DETAILS_BYPASS
  PAYMENT_ISSUE
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED
  DISMISSED
}

model User {
  id               String             @id @default(uuid()) @db.Uuid
  email            String             @unique @db.VarChar(320)
  passwordHash     String?
  authProvider     UserAuthProvider   @default(EMAIL)
  googleId         String?            @unique @db.VarChar(255)
  emailVerifiedAt  DateTime?
  emailVerificationTokenHash String?
  emailVerificationExpiresAt DateTime?
  passwordResetTokenHash String?
  passwordResetExpiresAt DateTime?
  passwordResetUsedAt DateTime?
  termsAcceptedAt DateTime?
  privacyAcceptedAt DateTime?
  role             UserRole
  status           UserStatus         @default(ACTIVE)
  refreshTokenHash String?
  profile          UserProfile?
  jobRequests      JobRequest[]       @relation("EmployerJobs")
  offers           Offer[]            @relation("ContractorOffers")
  tokenBalance     UserTokenBalance?
  tokenTransactions TokenTransaction[]
  payments         Payment[]
  notifications    Notification[]
  pushTokens       PushToken[]
  notificationPreference NotificationPreference?
  refundRequests   RefundRequest[]    @relation("RefundRequester")
  reviewedRefunds  RefundRequest[]    @relation("RefundReviewer")
  sentMessages      Message[]
  employerConversations Conversation[] @relation("EmployerConversations")
  contractorConversations Conversation[] @relation("ContractorConversations")
  employerChats     Chat[]            @relation("EmployerChats")
  contractorChats   Chat[]            @relation("ContractorChats")
  employerUnlocks   ContactUnlock[]   @relation("EmployerUnlocks")
  contractorUnlocks ContactUnlock[]   @relation("ContractorUnlocks")
  performedUnlocks  ContactUnlock[]   @relation("PerformedUnlocks")
  employerCompletions JobCompletion[]  @relation("EmployerCompletions")
  contractorCompletions JobCompletion[] @relation("ContractorCompletions")
  reviewsGiven      Review[]          @relation("EmployerReviews")
  reviewsReceived   Review[]          @relation("ContractorReviews")
  reviewsRemoved     Review[]          @relation("ReviewRemovals")
  employerReviewsGiven EmployerReview[] @relation("ContractorEmployerReviews")
  employerReviewsReceived EmployerReview[] @relation("ReviewedEmployerReviews")
  auditLogs          AuditLog[]        @relation("AdminAuditLogs")
  ratingSummary      ContractorRatingSummary? @relation("ContractorRatingSummary")
  employerRatingSummary EmployerRatingSummary? @relation("EmployerRatingSummary")
  portfolioImages    ContractorPortfolioImage[] @relation("ContractorPortfolioImages")
  serviceLocations    ContractorServiceLocation[] @relation("ContractorServiceLocations")
  serviceCategories   ContractorServiceCategory[] @relation("ContractorServiceCategories")
  verificationRequests ContractorVerification[] @relation("ContractorVerifications")
  reviewedVerifications ContractorVerification[] @relation("VerificationReviews")
  aiConversations  AiConversation[] @relation("EmployerAiConversations")
  aiJobDrafts      AiJobDraft[] @relation("EmployerAiJobDrafts")
  aiUsage          AiUsage[]
  reportsFiled     Report[] @relation("ReporterReports")
  reportsReviewed  Report[] @relation("ReportAdminReviews")
  analyticsEvents  AnalyticsEvent[]
  contractorOnboardingRequiredAt DateTime?
  contractorOnboardingCompletedAt DateTime?
  contractorOnboardingSkippedAt DateTime?
  welcomeBonusGrantedAt DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([role, status])
  @@index([role, welcomeBonusGrantedAt])
  @@index([emailVerificationTokenHash])
  @@index([passwordResetTokenHash])
}

model PushToken {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expoPushToken String   @unique @db.VarChar(255)
  platform      String   @db.VarChar(20)
  deviceId      String?  @db.VarChar(180)
  deviceName    String?  @db.VarChar(180)
  isActive      Boolean  @default(true)
  lastUsedAt    DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, isActive])
  @@index([platform, isActive])
  @@index([lastUsedAt])
}

model NotificationPreference {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  newJobsNearMe   Boolean  @default(false)
  offerUpdates    Boolean  @default(true)
  messages        Boolean  @default(true)
  reviews         Boolean  @default(true)
  paymentsRefunds Boolean  @default(true)
  systemAlerts    Boolean  @default(true)
  adminAlerts     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ContractorServiceLocation {
  id            String   @id @default(uuid()) @db.Uuid
  contractorId  String   @db.Uuid
  contractor    User     @relation("ContractorServiceLocations", fields: [contractorId], references: [id], onDelete: Cascade)
  locationKey   String   @db.VarChar(120)
  locationLabel String   @db.VarChar(160)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([contractorId, locationKey])
  @@index([locationKey])
}

model ContractorServiceCategory {
  id             String   @id @default(uuid()) @db.Uuid
  contractorId   String   @db.Uuid
  contractor     User     @relation("ContractorServiceCategories", fields: [contractorId], references: [id], onDelete: Cascade)
  categoryKey    String   @db.VarChar(100)
  subcategoryKey String?  @db.VarChar(100)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([contractorId, categoryKey, subcategoryKey])
  @@index([categoryKey, subcategoryKey])
}

model UserProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  displayName     String   @db.VarChar(120)
  phone           String?  @db.VarChar(50)
  location        String?  @db.VarChar(160)
  bio             String?  @db.VarChar(1000)
  avatarUrl       String?  @db.VarChar(2048)
  companyName     String?  @db.VarChar(160)
  tradeCategories String[] @default([])
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model JobRequest {
  id                            String       @id @default(uuid()) @db.Uuid
  employerId                    String       @db.Uuid
  employer                      User         @relation("EmployerJobs", fields: [employerId], references: [id], onDelete: Cascade)
  title                         String       @db.VarChar(160)
  description                   String       @db.VarChar(4000)
  category                      String       @db.VarChar(100)
  subcategory                   String       @db.VarChar(100)
  location                      String       @db.VarChar(160)
  status                        JobStatus    @default(ACTIVE)
  expiresAt                     DateTime
  contractorMarkedCompletedAt   DateTime?
  employerConfirmedCompletedAt  DateTime?
  images                        JobImage[]
  offers                        Offer[]
  contactUnlocks                ContactUnlock[]
  completions                    JobCompletion[]
  chats                         Chat[]
  reviews                       Review[]
  employerReviews               EmployerReview[]
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt

  @@index([employerId, status])
  @@index([category, subcategory, location])
  @@index([expiresAt])
}

model JobImage {
  id           String     @id @default(uuid()) @db.Uuid
  jobRequestId String     @db.Uuid
  jobRequest   JobRequest @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  url          String     @db.VarChar(2048)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([jobRequestId])
}

model Offer {
  id                      String         @id @default(uuid()) @db.Uuid
  jobRequestId            String         @db.Uuid
  contractorId            String         @db.Uuid
  jobRequest              JobRequest     @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  contractor              User           @relation("ContractorOffers", fields: [contractorId], references: [id], onDelete: Cascade)
  estimatedPrice          Decimal        @db.Decimal(12, 2)
  startDate               DateTime       @default(now())
  estimatedCompletionDays Int
  message                 String?        @db.VarChar(1500)
  status                  OfferStatus    @default(PENDING)
  selectedByEmployer      Boolean        @default(false)
  rejectionReason         OfferRejectionReason?
  deletedAt               DateTime?
  contactUnlock           ContactUnlock?
  chat                    Chat?
  completion              JobCompletion?
  review                  Review?
  employerReview          EmployerReview?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  @@index([jobRequestId, status])
  @@index([contractorId])
  @@index([deletedAt])
}

model ContractorPortfolioImage {
  id           String   @id @default(uuid()) @db.Uuid
  contractorId String   @db.Uuid
  contractor   User     @relation("ContractorPortfolioImages", fields: [contractorId], references: [id], onDelete: Cascade)
  url          String   @db.VarChar(2048)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())

  @@index([contractorId, sortOrder])
}

model ContractorVerification {
  id                 String                       @id @default(uuid()) @db.Uuid
  contractorId       String                       @db.Uuid
  contractor         User                         @relation("ContractorVerifications", fields: [contractorId], references: [id], onDelete: Cascade)
  documentUrl        String                       @db.VarChar(2048)
  documentMimeType   String                       @db.VarChar(100)
  status             ContractorVerificationStatus @default(PENDING_REVIEW)
  adminNote          String?                      @db.VarChar(2000)
  reviewedByAdminId  String?                      @db.Uuid
  reviewedByAdmin    User?                        @relation("VerificationReviews", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  reviewedAt         DateTime?
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([contractorId, status, createdAt])
  @@index([status, createdAt])
}

model ContactUnlock {
  id                 String           @id @default(uuid()) @db.Uuid
  jobRequestId       String           @db.Uuid
  offerId            String           @unique @db.Uuid
  contractorId       String           @db.Uuid
  employerId         String           @db.Uuid
  unlockedByContractorId String?      @db.Uuid
  tokenTransactionId String?          @unique @db.Uuid
  status             ContactUnlockStatus @default(PENDING)
  jobRequest         JobRequest       @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  offer              Offer            @relation(fields: [offerId], references: [id], onDelete: Cascade)
  contractor         User             @relation("ContractorUnlocks", fields: [contractorId], references: [id], onDelete: Cascade)
  employer           User             @relation("EmployerUnlocks", fields: [employerId], references: [id], onDelete: Cascade)
  unlockedByContractor User?          @relation("PerformedUnlocks", fields: [unlockedByContractorId], references: [id], onDelete: SetNull)
  tokenTransaction   TokenTransaction? @relation(fields: [tokenTransactionId], references: [id], onDelete: SetNull)
  conversation       Conversation?
  completion         JobCompletion?
  review             Review?
  employerReview      EmployerReview?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([jobRequestId])
  @@index([contractorId])
  @@index([employerId])
  @@index([status])
}

model Conversation {
  id              String        @id @default(uuid()) @db.Uuid
  contactUnlockId String       @unique @db.Uuid
  employerId      String       @db.Uuid
  contractorId    String       @db.Uuid
  contactUnlock   ContactUnlock @relation(fields: [contactUnlockId], references: [id], onDelete: Cascade)
  employer        User          @relation("EmployerConversations", fields: [employerId], references: [id], onDelete: Cascade)
  contractor      User          @relation("ContractorConversations", fields: [contractorId], references: [id], onDelete: Cascade)
  messages        Message[]
  lastMessageAt   DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([employerId, lastMessageAt])
  @@index([contractorId, lastMessageAt])
  @@index([createdAt])
}

model Chat {
  id           String     @id @default(uuid()) @db.Uuid
  jobRequestId String     @db.Uuid
  offerId      String     @unique @db.Uuid
  employerId   String     @db.Uuid
  contractorId String     @db.Uuid
  jobRequest   JobRequest @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  offer        Offer      @relation(fields: [offerId], references: [id], onDelete: Cascade)
  employer     User       @relation("EmployerChats", fields: [employerId], references: [id], onDelete: Cascade)
  contractor   User       @relation("ContractorChats", fields: [contractorId], references: [id], onDelete: Cascade)
  messages     Message[]
  unlockedAt   DateTime   @default(now())
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([jobRequestId])
  @@index([employerId])
  @@index([contractorId])
}

model Message {
  id        String      @id @default(uuid()) @db.Uuid
  chatId    String?     @db.Uuid
  conversationId String? @db.Uuid
  senderId  String      @db.Uuid
  chat      Chat?       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender    User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  type      MessageType @default(TEXT)
  content   String      @db.VarChar(4000)
  isRead    Boolean     @default(false)
  metadata  Json?
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([chatId, createdAt])
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([isRead, createdAt])
}

model JobCompletion {
  id                 String              @id @default(uuid()) @db.Uuid
  jobRequestId       String              @db.Uuid
  offerId            String              @unique @db.Uuid
  contactUnlockId    String              @unique @db.Uuid
  employerId         String              @db.Uuid
  contractorId       String              @db.Uuid
  status             JobCompletionStatus @default(PENDING_EMPLOYER_CONFIRMATION)
  contractorMarkedAt DateTime?
  employerConfirmedAt DateTime?
  jobRequest         JobRequest          @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  offer              Offer               @relation(fields: [offerId], references: [id], onDelete: Cascade)
  contactUnlock      ContactUnlock       @relation(fields: [contactUnlockId], references: [id], onDelete: Cascade)
  employer           User                @relation("EmployerCompletions", fields: [employerId], references: [id], onDelete: Cascade)
  contractor         User                @relation("ContractorCompletions", fields: [contractorId], references: [id], onDelete: Cascade)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([jobRequestId])
  @@index([employerId, status])
  @@index([contractorId, status])
  @@index([status, createdAt])
}

model Review {
  id                 String     @id @default(uuid()) @db.Uuid
  jobRequestId       String     @db.Uuid
  offerId            String     @unique @db.Uuid
  contactUnlockId    String?    @unique @db.Uuid
  employerId         String     @db.Uuid
  contractorId       String     @db.Uuid
  jobRequest         JobRequest @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  offer              Offer      @relation(fields: [offerId], references: [id], onDelete: Cascade)
  contactUnlock      ContactUnlock? @relation(fields: [contactUnlockId], references: [id], onDelete: Cascade)
  employer           User       @relation("EmployerReviews", fields: [employerId], references: [id], onDelete: Cascade)
  contractor         User       @relation("ContractorReviews", fields: [contractorId], references: [id], onDelete: Cascade)
  rating             Int
  comment            String?    @db.VarChar(1500)
  contractorReply    String?    @db.VarChar(1500)
  contractorReplyAt  DateTime?
  status             ReviewStatus @default(ACTIVE)
  removedByAdminId   String?    @db.Uuid
  removedByAdmin     User?      @relation("ReviewRemovals", fields: [removedByAdminId], references: [id], onDelete: SetNull)
  removedAt          DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@unique([jobRequestId, contractorId])
  @@index([contractorId, status, removedAt])
  @@index([employerId])
}

model ContractorRatingSummary {
  id            String   @id @default(uuid()) @db.Uuid
  contractorId  String   @unique @db.Uuid
  contractor    User     @relation("ContractorRatingSummary", fields: [contractorId], references: [id], onDelete: Cascade)
  averageRating Decimal  @default(0) @db.Decimal(3, 2)
  totalReviews  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model EmployerReview {
  id                 String       @id @default(uuid()) @db.Uuid
  jobRequestId       String       @db.Uuid
  offerId            String       @unique @db.Uuid
  contactUnlockId    String?      @unique @db.Uuid
  employerId         String       @db.Uuid
  contractorId       String       @db.Uuid
  jobRequest         JobRequest   @relation(fields: [jobRequestId], references: [id], onDelete: Cascade)
  offer              Offer        @relation(fields: [offerId], references: [id], onDelete: Cascade)
  contactUnlock      ContactUnlock? @relation(fields: [contactUnlockId], references: [id], onDelete: Cascade)
  employer           User         @relation("ReviewedEmployerReviews", fields: [employerId], references: [id], onDelete: Cascade)
  contractor         User         @relation("ContractorEmployerReviews", fields: [contractorId], references: [id], onDelete: Cascade)
  rating             Int
  comment            String?      @db.VarChar(1500)
  status             ReviewStatus @default(ACTIVE)
  removedByAdminId   String?      @db.Uuid
  removedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([jobRequestId, contractorId])
  @@index([employerId, status, removedAt])
  @@index([contractorId])
}

model EmployerRatingSummary {
  id            String   @id @default(uuid()) @db.Uuid
  employerId    String   @unique @db.Uuid
  employer      User     @relation("EmployerRatingSummary", fields: [employerId], references: [id], onDelete: Cascade)
  averageRating Decimal  @default(0) @db.Decimal(3, 2)
  totalReviews  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TokenPackage {
  id            String             @id @default(uuid()) @db.Uuid
  title         String             @unique @db.VarChar(100)
  tokenCount    Int
  price         Decimal            @db.Decimal(12, 2)
  currency      String             @default("EUR") @db.Char(3)
  isActive      Boolean            @default(true)
  transactions  TokenTransaction[]
  payments      Payment[]
  storeProducts StoreProduct[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model StoreProduct {
  id                String        @id @default(uuid()) @db.Uuid
  platformProductId String        @db.VarChar(180)
  tokenPackageId    String        @db.Uuid
  platform          StorePlatform @default(REVENUECAT)
  isActive          Boolean       @default(true)
  tokenPackage      TokenPackage  @relation(fields: [tokenPackageId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@unique([platform, platformProductId])
  @@index([tokenPackageId])
  @@index([platform, isActive])
}

model Payment {
  id                      String        @id @default(uuid()) @db.Uuid
  userId                  String        @db.Uuid
  tokenPackageId          String        @db.Uuid
  provider                PaymentProvider @default(LEGACY_STRIPE)
  platform                StorePlatform?
  platformProductId       String?       @db.VarChar(180)
  revenueCatEventId       String?       @unique @db.VarChar(255)
  revenueCatTransactionId String?       @unique @db.VarChar(255)
  stripeCheckoutSessionId String?       @unique @db.VarChar(255)
  stripePaymentIntentId   String?       @unique @db.VarChar(255)
  amount                  Decimal       @db.Decimal(12, 2)
  currency                String        @default("EUR") @db.Char(3)
  status                  PaymentStatus @default(PENDING)
  failureReason           String?       @db.VarChar(1000)
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenPackage            TokenPackage  @relation(fields: [tokenPackageId], references: [id], onDelete: Restrict)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  @@index([userId, createdAt])
  @@index([tokenPackageId])
  @@index([status, createdAt])
  @@index([provider, status, createdAt])
  @@index([platformProductId])
  @@index([revenueCatTransactionId])
}

model UserTokenBalance {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  version   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenTransaction {
  id            String               @id @default(uuid()) @db.Uuid
  userId        String               @db.Uuid
  packageId     String?              @db.Uuid
  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  package       TokenPackage?        @relation(fields: [packageId], references: [id], onDelete: SetNull)
  type          TokenTransactionType
  amount        Int
  description   String               @db.VarChar(500)
  balanceAfter  Int
  externalRef   String?              @db.VarChar(255)
  relatedRefundRequestId String?     @unique @db.Uuid
  relatedRefundRequest   RefundRequest? @relation("RefundLedgerTransaction", fields: [relatedRefundRequestId], references: [id], onDelete: SetNull)
  contactUnlock ContactUnlock?
  refundRequest RefundRequest?       @relation("RefundPurchaseTransaction")
  createdAt     DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([type])
}

model RefundRequest {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @db.Uuid
  tokenTransactionId String       @unique @db.Uuid
  requestedBy    User             @relation("RefundRequester", fields: [userId], references: [id], onDelete: Cascade)
  tokenTransaction TokenTransaction @relation("RefundPurchaseTransaction", fields: [tokenTransactionId], references: [id], onDelete: Restrict)
  refundTransaction TokenTransaction? @relation("RefundLedgerTransaction")
  amount         Int
  status         RefundStatus     @default(PENDING)
  reason         String           @db.VarChar(2000)
  adminNote      String?          @db.VarChar(2000)
  reviewedByAdminId String?       @db.Uuid
  reviewedBy     User?            @relation("RefundReviewer", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  reviewedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @db.Uuid
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String           @db.VarChar(160)
  body      String           @db.VarChar(1000)
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt, createdAt])
  @@index([userId, isRead, createdAt])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  adminId    String   @db.Uuid
  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id], onDelete: Restrict)
  action     String   @db.VarChar(80)
  entityType String   @db.VarChar(80)
  entityId   String   @db.VarChar(120)
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Report {
  id                String           @id @default(uuid()) @db.Uuid
  reporterId        String           @db.Uuid
  reporter          User             @relation("ReporterReports", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType        ReportTargetType
  targetId          String           @db.Uuid
  reason            ReportReason
  description       String?          @db.VarChar(1500)
  status            ReportStatus     @default(PENDING)
  reviewedByAdminId String?          @db.Uuid
  reviewedByAdmin   User?            @relation("ReportAdminReviews", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  adminNote         String?          @db.VarChar(1500)
  reviewedAt        DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([reporterId, createdAt])
  @@index([targetType, targetId])
  @@index([status, createdAt])
  @@index([createdAt])
}

model AnalyticsEvent {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String?   @db.Uuid
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  role       UserRole?
  sessionId  String    @db.VarChar(120)
  eventName  String    @db.VarChar(120)
  screen     String    @db.VarChar(120)
  entityType String?   @db.VarChar(60)
  entityId   String?   @db.VarChar(120)
  metadata   Json?
  platform   String    @db.VarChar(40)
  appVersion String?   @db.VarChar(40)
  createdAt  DateTime  @default(now())

  @@index([createdAt])
  @@index([userId])
  @@index([eventName])
  @@index([screen])
  @@index([role])
}

model AiConversation {
  id         String               @id @default(uuid()) @db.Uuid
  employerId String              @db.Uuid
  employer   User                @relation("EmployerAiConversations", fields: [employerId], references: [id], onDelete: Cascade)
  status     AiConversationStatus @default(ACTIVE)
  messages   AiMessage[]
  draft      AiJobDraft?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@index([employerId, status, updatedAt])
}

model AiMessage {
  id             String         @id @default(uuid()) @db.Uuid
  conversationId String         @db.Uuid
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AiMessageRole
  content        String         @db.VarChar(2000)
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
  @@index([role, createdAt])
}

model AiJobDraft {
  id             String           @id @default(uuid()) @db.Uuid
  conversationId String           @unique @db.Uuid
  employerId     String           @db.Uuid
  conversation   AiConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  employer       User             @relation("EmployerAiJobDrafts", fields: [employerId], references: [id], onDelete: Cascade)
  title          String           @db.VarChar(160)
  description    String           @db.VarChar(4000)
  categoryKey    String           @db.VarChar(100)
  subcategoryKey String           @db.VarChar(100)
  locationKey    String           @db.VarChar(120)
  status         AiJobDraftStatus @default(DRAFT)
  publishedJobId String?          @db.Uuid
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([employerId, status, updatedAt])
  @@index([categoryKey, subcategoryKey, locationKey])
}

model AiUsage {
  id               String   @id @default(uuid()) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dateUtc          DateTime @db.Date
  userMessageCount Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([userId, dateUtc])
  @@index([dateUtc])
}
