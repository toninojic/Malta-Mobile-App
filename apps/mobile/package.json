{
  "name": "@malta-marketplace/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "api-url:set": "node scripts/set-api-url.mjs",
    "api-url:check": "node scripts/check-api-url.mjs",
    "build:android:preview": "node ../../scripts/eas-no-deprecation.mjs build --platform android --profile preview",
    "build:android:preview:local": "node ../../scripts/eas-no-deprecation.mjs build --platform android --profile preview --local",
    "build:android:production": "node ../../scripts/eas-no-deprecation.mjs build --platform android --profile production",
    "submit:android:production": "node ../../scripts/eas-no-deprecation.mjs submit --platform android --profile production",
    "build:android:apk": "npm run build:android:preview",
    "build:android:apk:local": "npm run build:android:preview:local",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.3.0",
    "@react-navigation/native": "^7.1.0",
    "@react-navigation/native-stack": "^7.3.0",
    "@tanstack/react-query": "^5.62.8",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-image-picker": "~17.0.8",
    "expo-notifications": "~0.32.12",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^0.542.0",
    "react": "19.1.0",
    "react-native": "0.81.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^10.3.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  }
}
