        "EXPO_PUBLIC_API_LOGGING": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://condiment-ransack-ducky.ngrok-free.dev/api/v1",
        "EXPO_PUBLIC_API_LOGGING": "true"
      },
